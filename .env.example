# ============================================================
# hey.kamori 환경 변수 템플릿
# 이 파일을 복사해서 .env.local 로 저장하고 값을 채우세요.
# .env.local은 절대 Git에 올리지 마세요 (.gitignore로 보호됨).
# ============================================================

# ------------------------------------------------------------
# Supabase
# 값을 얻는 곳: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------

# Supabase 프로젝트 URL (공개용, 클라이언트에서도 사용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (공개용, 클라이언트에서도 사용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (서버 전용! 절대 클라이언트 노출 금지!)
# 이 키는 모든 RLS 정책을 우회하므로 매우 민감함
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# Auth (인증)
# ------------------------------------------------------------

# 관리자 이메일 (이 이메일만 /admin에 접근 가능)
# 본인 이메일을 정확히 입력하세요
ADMIN_EMAIL=your-email@example.com

# ------------------------------------------------------------
# Site (사이트 정보)
# ------------------------------------------------------------

# 배포된 사이트 URL (Auth 리다이렉트에 사용)
# 로컬 개발 시: http://localhost:3000
# 배포 시: https://hey-kamori.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# 선택사항 (나중에 추가해도 됨)
# ------------------------------------------------------------

# Vercel 배포 환경 (자동 설정됨, 로컬에서는 비워두기)
# VERCEL_ENV=
